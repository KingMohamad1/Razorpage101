@page
@model RazorBoatApp2026InClass.Pages.Members.LoginModel
@{
}

<h3>Login form</h3>
@Model.Message
<form method="post">
    <table>
        <tr>
            <td>Email</td>
            <td><Input type="text" asp-for="@Model" /></td>
        </tr>
        <tr>
            <td>Password</td>
            <td><Input type="password" asp-for="@Model" /></td>
        </tr>
        <tr>
            <td>&nbsp</td>
            <td><Input type="submit" value="Login" /></td>
        </tr>
    </table>
    <a asp-page="CreateUser">Create a new user</a>
</form>